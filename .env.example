# ─── Database ─────────────────────────────────────────────────────────────────
MONGO_PROD=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>

# ─── Auth ─────────────────────────────────────────────────────────────────────
SECRET_TOKEN=change-me-to-a-long-random-string

# ─── App ──────────────────────────────────────────────────────────────────────
APP_URL=https://api.greenbazaar.cloud

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=https://greenbazaar.cloud

# ─── Admin seed credentials ───────────────────────────────────────────────────
ADMIN_EMAIL=admin@greenbazaar.cloud
ADMIN_PASSWORD=change-me-strong-password
ADMIN_NICKNAME=superadmin
ADMIN_FIRSTNAME=System
ADMIN_LASTNAME=Admin

# ─── Ports (host-side mappings) ───────────────────────────────────────────────
PORT_API_HOST=4001
PORT_BATCH_HOST=4002

# ─── Checkout ─────────────────────────────────────────────────────────────────
CHECKOUT_CURRENCY=USD
CHECKOUT_TAX_RATE=0.1
CHECKOUT_DELIVERY_FEE=5
CHECKOUT_FREE_DELIVERY_THRESHOLD=50

# ─── Product Reviews ──────────────────────────────────────────────────────────
# Comma-separated order statuses that qualify a user to leave a review
# REVIEW_ELIGIBLE_ORDER_STATUSES=DELIVERED,COMPLETED
REVIEW_VERIFIED_ORDER_MODE=RELAXED
