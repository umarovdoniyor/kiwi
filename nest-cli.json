{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/kiwi/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/kiwi/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/kiwi",
  "projects": {
    "kiwi": {
      "type": "application",
      "root": "apps/kiwi",
      "entryFile": "main",
      "sourceRoot": "apps/kiwi/src",
      "compilerOptions": {
        "tsConfigPath": "apps/kiwi/tsconfig.app.json"
      }
    },
    "kiwi-batch": {
      "type": "application",
      "root": "apps/kiwi-batch",
      "entryFile": "main",
      "sourceRoot": "apps/kiwi-batch/src",
      "compilerOptions": {
        "tsConfigPath": "apps/kiwi-batch/tsconfig.app.json"
      }
    }
  }
}